# Twilio Voice browser SDK access-token configuration.
# Copy this file to .env.local and fill in real values. Do not commit .env.local.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_VOICE_IDENTITY=swva-dashboard
# Optional but recommended for outbound PSTN dialing from the browser.
# Use a Twilio phone number owned by this account, in E.164 format.
TWILIO_CALLER_ID=
# Production domain used for Twilio Console webhook configuration.
NEXT_PUBLIC_APP_URL=https://swvavoice.com
