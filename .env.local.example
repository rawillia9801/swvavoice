# Twilio Voice browser SDK access-token configuration.
# Copy this file to .env.local and fill in real values. Do not commit .env.local.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_VOICE_IDENTITY=swva-dashboard
# Optional but recommended for outbound PSTN dialing from the browser.
# Use a Twilio phone number owned by this account, in E.164 format.
TWILIO_CALLER_ID=
# Production domain used for Twilio Console webhook configuration.
NEXT_PUBLIC_APP_URL=https://swvavoice.com
# Password gate for dashboard pages. Change this in production if needed.
SWVA_DASHBOARD_PASSWORD=Today2020

# Supabase server-side data access for Contacts and Messages.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional fallback when your Supabase RLS policies allow server-side anon writes.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_CONTACTS_TABLE=contacts
SUPABASE_CONVERSATIONS_TABLE=conversations
SUPABASE_MESSAGES_TABLE=conversation_messages
